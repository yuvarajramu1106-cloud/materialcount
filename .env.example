# .env.example
# Copy this file to .env and fill in your values
# Then load with: pip install python-dotenv

# Flask
FLASK_SECRET_KEY=your-secret-key-here
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False

# Model
MODEL_PATH=model/construction_materials.pt
CONF_THRESHOLD=0.50
IOU_THRESHOLD=0.45

# Database (SQLite default — leave blank)
DB_BACKEND=sqlite
# DB_BACKEND=mysql
# MYSQL_HOST=localhost
# MYSQL_USER=root
# MYSQL_PASSWORD=password
# MYSQL_DATABASE=construction_ai

# Camera
DEFAULT_CAMERA_ID=0
